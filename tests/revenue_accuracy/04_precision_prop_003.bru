meta {
  name: prop-003 revenue is exactly $6100.50
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/api/v1/dashboard/summary?property_id=prop-003
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: Bearer {{tokenTenantA}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("property_id is 'prop-003'", function() {
    const body = res.getBody();
    expect(body.property_id).to.equal("prop-003");
  });

  test("total_revenue is exactly 6100.5 (seed: 2850.00 + 3250.50)", function() {
    const body = res.getBody();
    expect(body.total_revenue).to.equal(6100.5);
  });

  test("reservations_count is exactly 2", function() {
    const body = res.getBody();
    expect(body.reservations_count).to.equal(2);
  });

  test("BUG FIX VERIFIED: no float precision drift", function() {
    const body = res.getBody();
    const rounded = Math.round(body.total_revenue * 100) / 100;
    expect(body.total_revenue).to.equal(rounded);
  });

  test("currency is 'USD'", function() {
    const body = res.getBody();
    expect(body.currency).to.equal("USD");
  });
}
