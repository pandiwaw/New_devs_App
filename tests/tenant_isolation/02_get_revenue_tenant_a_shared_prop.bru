meta {
  name: Tenant A revenue for shared prop-001 (Beach House Alpha)
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/dashboard/summary?property_id=prop-001
  body: none
  auth: none
}

headers {
  Accept: application/json
  Authorization: Bearer {{tokenTenantA}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("property_id is exactly 'prop-001'", function() {
    const body = res.getBody();
    expect(body.property_id).to.equal("prop-001");
  });

  test("total_revenue is exactly 2250.0 (1250 + 333.333 + 333.333 + 333.334 = 2250.000 → rounded to 2250.00)", function() {
    const body = res.getBody();
    expect(body.total_revenue).to.equal(2250.0);
  });

  test("reservations_count is exactly 4", function() {
    const body = res.getBody();
    expect(body.reservations_count).to.equal(4);
  });

  test("currency is 'USD'", function() {
    const body = res.getBody();
    expect(body.currency).to.equal("USD");
  });
}
