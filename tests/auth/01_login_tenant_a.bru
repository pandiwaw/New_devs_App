meta {
  name: Login Tenant A (Sunset Properties)
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/login
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "email": "sunset@propertyflow.com",
    "password": "client_a_2024"
  }
}

script:post-response {
  const body = res.getBody();
  if (res.getStatus() === 200 && body.access_token) {
    bru.setVar("tokenTenantA", body.access_token);
  }
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("access_token is a non-empty string", function() {
    const body = res.getBody();
    expect(body).to.have.property("access_token");
    expect(body.access_token).to.be.a("string");
    expect(body.access_token.length).to.be.above(0);
  });

  test("token_type is exactly 'bearer'", function() {
    const body = res.getBody();
    expect(body.token_type).to.equal("bearer");
  });

  test("user.id is 'user-sunset'", function() {
    const body = res.getBody();
    expect(body.user.id).to.equal("user-sunset");
  });

  test("user.email is 'sunset@propertyflow.com'", function() {
    const body = res.getBody();
    expect(body.user.email).to.equal("sunset@propertyflow.com");
  });

  test("user.name is 'Sunset Properties Manager'", function() {
    const body = res.getBody();
    expect(body.user.name).to.equal("Sunset Properties Manager");
  });

  test("user.tenant_id is 'tenant-a'", function() {
    const body = res.getBody();
    expect(body.user.tenant_id).to.equal("tenant-a");
  });

  test("user.is_admin is false", function() {
    const body = res.getBody();
    expect(body.user.is_admin).to.equal(false);
  });

  test("user.permissions is empty array", function() {
    const body = res.getBody();
    expect(body.user.permissions).to.be.an("array");
    expect(body.user.permissions.length).to.equal(0);
  });

  test("user.cities is empty array", function() {
    const body = res.getBody();
    expect(body.user.cities).to.be.an("array");
    expect(body.user.cities.length).to.equal(0);
  });

  test("error is null", function() {
    const body = res.getBody();
    expect(body.error).to.be.null;
  });
}
