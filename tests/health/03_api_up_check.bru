meta {
  name: API up check returns exactly {"status": "up"}
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/up
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("status is exactly 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("body.status is exactly 'up'", function() {
    const body = res.getBody();
    expect(body.status).to.equal("up");
  });
}
